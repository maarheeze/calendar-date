{
    "name": "maarheeze/calendar-date",
    "description": "a timezone-agnostic calendar date value object",
    "type": "library",
    "license": "MIT",
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "Maarheeze\\CalendarDate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "maarheeze/phpcs": "^1.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12"
    }
}
